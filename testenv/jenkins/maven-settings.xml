<?xml version="1.0" encoding="UTF-8"?>
<!--
  maven-settings.xml — mounted into Jenkins build pods at /root/.m2/settings.xml
  via the maven-settings ConfigMap in the jenkins-builds namespace.

  Build pods reach Artifactory via host.k3d.internal:8082 — k3d injects this
  hostname (→ host machine IP) into every pod's /etc/hosts.

  maven-internal resolves com.myorg:* artifacts (deployed by create.sh).
  All other dependencies resolve directly from Maven Central.

  ARTIFACTORY_PASSWORD is injected from the artifactory-credentials Secret.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0
                              https://maven.apache.org/xsd/settings-1.2.0.xsd">

  <!-- Explicit mirror overrides Maven 3.8+ built-in HTTP blocker (maven-default-http-blocker). -->
  <mirrors>
    <mirror>
      <id>maven-internal</id>
      <mirrorOf>maven-internal</mirrorOf>
      <url>http://host.k3d.internal:8082/artifactory/maven-internal/</url>
    </mirror>
  </mirrors>

  <servers>
    <server>
      <id>maven-internal</id>
      <username>admin</username>
      <password>${env.ARTIFACTORY_PASSWORD}</password>
    </server>
  </servers>

  <profiles>
    <profile>
      <id>ap3</id>
      <repositories>
        <repository>
          <id>maven-internal</id>
          <url>http://host.k3d.internal:8082/artifactory/maven-internal/</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
      </repositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>ap3</activeProfile>
  </activeProfiles>

</settings>
