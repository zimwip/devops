# .env.example — copy to .env and fill in your values
# .env is in .gitignore and must never be committed.
# These values override platform.yaml settings at runtime.
#
# Usage:
#   cp .env.example .env
#   set -a && source .env && set +a   # Linux/macOS
#   # Or use direnv: https://direnv.net

# ── GitHub ────────────────────────────────────────────────────────────────────
# Required for: service create (template/fork modes), release notes
# Scopes needed:
#   org  account_type: repo, admin:org (branch protection)
#   user account_type: repo only
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── Jenkins ───────────────────────────────────────────────────────────────────
# Required for: deploy, service create (pipeline registration)
# Jenkins → Manage Jenkins → Users → <your user> → Configure → Add new Token
JENKINS_USER=your_jenkins_username
JENKINS_TOKEN=your_jenkins_api_token

# ── Dashboard server ──────────────────────────────────────────────────────────
# PORT=5173          # API port (default: 5173)
# RELOAD=1           # Hot-reload (set to 0 in production)

# ── Git identity for automated commits ───────────────────────────────────────
# Used by env_manager and deployer when committing versions.yaml changes.
# Only needed if running the dashboard as a service (not interactive CLI).
# GIT_AUTHOR_NAME="AP3 Dashboard"
# GIT_AUTHOR_EMAIL="ap3@my-org.com"
# GIT_COMMITTER_NAME="AP3 Dashboard"
# GIT_COMMITTER_EMAIL="ap3@my-org.com"
