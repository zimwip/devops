    identifier: 'platform-shared-lib@{{SHARED_LIB_VERSION}}',
    retriever: modernSCM([$class: 'jenkins.plugins.git.GitSCMSource',
                           remote: '{{LIB_REPO_URL}}',
                           credentialsId: 'github-token'])
)

// Build config is in .platform/build.yaml; version is in version.txt.
// No template parameter needed — both files are present in every scaffolded service.
