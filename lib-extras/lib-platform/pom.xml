<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.myorg</groupId>
  <artifactId>lib-platform</artifactId>
  <version>1.3.0</version>
  <packaging>jar</packaging>
  <name>Platform Library</name>
  <description>
    Cross-cutting platform library: security, logging, tracing, pub/sub stubs.
    Published to the local Artifactory instance during testenv bootstrap so that
    service builds can resolve com.myorg:lib-platform without a real Artifactory.
  </description>

  <properties>
    <java.version>17</java.version>
    <maven.compiler.source>${java.version}</maven.compiler.source>
    <maven.compiler.target>${java.version}</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>

  <!--
    Deployment target: Artifactory local repository 'maven-internal'.
    create.sh calls mvn deploy from inside a container on the testenv_default
    network, so 'artifactory' resolves via Docker DNS to port 8082.
  -->
  <distributionManagement>
    <repository>
      <id>artifactory</id>
      <url>http://artifactory:8082/artifactory/maven-internal/</url>
    </repository>
  </distributionManagement>

</project>
