<?xml version="1.0" encoding="UTF-8"?>
<!--
  maven-settings.xml — mounted into Jenkins build pods at /root/.m2/settings.xml
  via the maven-settings ConfigMap in the jenkins-builds namespace.

  Build pods reach Artifactory via host.k3d.internal:8082 — k3d injects this
  hostname (→ host machine IP) into every pod's /etc/hosts.

  All Maven traffic is routed through the maven-public virtual repo, which
  aggregates maven-internal (com.myorg:* artifacts) and maven-central-proxy
  (cached proxy of Maven Central). This means each artifact is fetched from
  Central only once and served from Artifactory cache on subsequent builds.

  ARTIFACTORY_PASSWORD is injected from the artifactory-credentials Secret.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0
                              https://maven.apache.org/xsd/settings-1.2.0.xsd">

  <!-- Route all Maven traffic through Artifactory. Overrides the built-in
       maven-default-http-blocker (Maven 3.8+) for the internal HTTP endpoint. -->
  <mirrors>
    <mirror>
      <id>maven-public</id>
      <mirrorOf>*</mirrorOf>
      <url>http://host.k3d.internal:8082/artifactory/maven-public/</url>
    </mirror>
  </mirrors>

  <servers>
    <server>
      <id>maven-public</id>
      <username>admin</username>
      <password>${env.ARTIFACTORY_PASSWORD}</password>
    </server>
    <server>
      <id>maven-internal</id>
      <username>admin</username>
      <password>${env.ARTIFACTORY_PASSWORD}</password>
    </server>
  </servers>

</settings>
